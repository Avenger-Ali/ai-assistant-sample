# Copy this to .env and fill in your values

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/shadow-ai

# JWT signing secret (generate a strong random string)
JWT_SECRET=change-me-to-a-long-random-secret

# Client URL (update for production)
CLIENT_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# AI APIs (only Gemini is required for basic use — it has a free tier)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=   # optional — enables Claude model in desktop app
OPENAI_API_KEY=      # optional — enables ChatGPT model in desktop app

# Razorpay payments
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Admin accounts — full access without any subscription
ADMIN_EMAILS=khajamoulalis@gmail.com,skhajamoulali8@gmail.com

# Desktop overlay token secret (separate from JWT_SECRET for security)
DESKTOP_TOKEN_SECRET=change-me-too
