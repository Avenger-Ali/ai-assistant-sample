{
  "name": "shadow-ai",
  "version": "6.0.0",
  "description": "Shadow AI — Real-time AI Interview Assistant",
  "private": true,
  "scripts": {
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm start",
    "dev:desktop": "cd desktop && npm start",
    "install:all": "npm run install:server && npm run install:client && npm run install:desktop",
    "install:server":  "cd server && npm install",
    "install:client":  "cd client && npm install",
    "install:desktop": "cd desktop && npm install",
    "build:client": "cd client && npm run build",
    "start": "cd server && node index.js"
  }
}
