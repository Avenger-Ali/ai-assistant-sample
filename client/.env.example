# Copy to .env

# Backend API URL — for production, point to your deployed server
REACT_APP_API_URL=http://localhost:5000/api

# Google OAuth Client ID from console.cloud.google.com
REACT_APP_GOOGLE_CLIENT_ID=

# Gemini API key (free from aistudio.google.com)
REACT_APP_GEMINI_KEY=

# Razorpay PUBLIC key only (never put secret key here)
REACT_APP_RAZORPAY_KEY_ID=
